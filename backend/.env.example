# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/embroidery_site
# Atlas example:
# MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/embroidery_site

# --- Auth ---
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- First admin (used by `npm run seed`) ---
ADMIN_NAME=Site Admin
ADMIN_EMAIL=admin@embroidery.local
ADMIN_PASSWORD=ChangeMe123!

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

# --- Payments (optional) ---
# If both STRIPE_* vars are set, the backend uses real Stripe Checkout.
# Otherwise it falls back to a mock provider that completes instantly for local testing.
# Get keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_…
# STRIPE_WEBHOOK_SECRET=whsec_…
FRONTEND_BASE=http://localhost:5173
